/* ===== CONTROVERSIAL CAROUSEL ===== */
#controversial-carousel {
  margin-top: 4rem;
  padding: 2rem;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border: 2px solid #ff006e;
  border-radius: 15px;
  box-shadow: 0 0 30px rgba(255, 0, 110, 0.3);
}

.carousel-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  border-bottom: 1px solid #ff006e;
  padding-bottom: 1rem;
}

.carousel-header h2 {
  color: #ff006e;
  font-family: 'Courier New', monospace;
  font-size: 1.8rem;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.controversy-indicator {
  background: #ff006e;
  color: #fff;
  padding: 0.5rem 1rem;
  border-radius: 20px;
  font-weight: bold;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.carousel-container {
  position: relative;
  max-width: 800px;
  margin: 0 auto;
  overflow: hidden;
}

.carousel-track {
  display: flex;  transition: transform 0.5s ease-in-out;
}

.carousel-slide {
  min-width: 100%;
  position: relative;
  opacity: 0;
  transition: opacity 0.5s ease-in-out;
  display: none;
}

.carousel-slide.active {
  opacity: 1;
  display: block;
}

.carousel-slide img,
.carousel-slide video {
  width: 100%;
  max-height: 500px;
  object-fit: cover;
  border-radius: 10px;
  border: 1px solid #ff006e;
}

.carousel-caption {
  padding: 1.5rem;
  background: rgba(0, 0, 0, 0.8);
  border-radius: 0 0 10px 10px;
  margin-top: -5px;
}

.carousel-caption p {
  color: #fff;
  font-size: 1.1rem;
  margin-bottom: 1rem;
  line-height: 1.6;
}

.carousel-meta {
  display: flex;
  gap: 1rem;
  align-items: center;
  flex-wrap: wrap;
  color: #aaa;
  font-size: 0.9rem;
}

.carousel-meta .tags {
  color: #ff006e;}

.controversy-level {
  letter-spacing: 2px;
}

.like-btn {
  background: transparent;
  border: 1px solid #ff006e;
  color: #ff006e;
  padding: 0.3rem 0.8rem;
  border-radius: 15px;
  cursor: pointer;
  transition: all 0.3s;
  margin-left: auto;
}

.like-btn:hover {
  background: #ff006e;
  color: #fff;
  transform: scale(1.1);
}

.carousel-btn {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(255, 0, 110, 0.8);
  color: #fff;
  border: none;
  padding: 1rem 1.5rem;
  font-size: 1.5rem;
  cursor: pointer;
  border-radius: 5px;
  transition: all 0.3s;
  z-index: 10;
}

.carousel-btn:hover {
  background: #ff006e;
  transform: translateY(-50%) scale(1.1);
}

.carousel-btn.prev { left: 10px; }
.carousel-btn.next { right: 10px; }

.carousel-dots {
  display: flex;
  justify-content: center;
  gap: 0.5rem;  margin-top: 1.5rem;
}

.dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #444;
  cursor: pointer;
  transition: all 0.3s;
}

.dot.active {
  background: #ff006e;
  transform: scale(1.3);
}

.dot:hover {
  background: #ff006e;
}

/* Responsive */
@media (max-width: 768px) {
  .carousel-header h2 {
    font-size: 1.3rem;
  }
  
  .carousel-btn {
    padding: 0.5rem 0.8rem;
    font-size: 1.2rem;
  }
  
  .carousel-slide img,
  .carousel-slide video {
    max-height: 300px;
  }
  
  .carousel-meta {
    font-size: 0.8rem;
  }
}
